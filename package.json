{
  "name": "taptap-maker-plus",
  "private": true,
  "version": "0.14.0",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "sync:version": "node scripts/sync-app-version.mjs",
    "dev": "npm run sync:version && npm run desktop:dev",
    "dev:browser": "npm-run-all --parallel dev:web dev:server",
    "dev:web": "npm run dev --workspace @taptap/web",
    "dev:server": "npm run dev --workspace @taptap/server",
    "build": "npm run sync:version && npm run build --workspace @taptap/server && npm run build --workspace @taptap/web",
    "prepare:desktop": "node scripts/prepare-desktop-resources.mjs",
    "build:desktop": "npm run build && npm run sync:version && npm run prepare:desktop && npm run verify:desktop",
    "typecheck": "npm run typecheck --workspace @taptap/server && npm run typecheck --workspace @taptap/web",
    "lint": "npm run lint --workspace @taptap/server && npm run lint --workspace @taptap/web",
    "verify:assets": "tsx scripts/verify-asset-governance.ts",
    "verify:mcp-runtime": "tsx scripts/verify-mcp-runtime-launch.ts",
    "collect:diagnostics": "node scripts/collect-desktop-diagnostics.mjs --open",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build --features devtools",
    "verify:desktop": "tsx scripts/verify-desktop-readiness.ts",
    "verify:installer": "node scripts/verify-nsis-bundle.mjs",
    "sync:update-feed": "node scripts/sync-update-feed.mjs",
    "publish:update-feed": "node scripts/publish-update-feed.mjs",
    "publish:update-release": "node scripts/publish-update-release.mjs",
    "set:version-from-manifest": "node scripts/set-app-version-from-manifest.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.3",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "npm-run-all": "^4.1.5"
  }
}
