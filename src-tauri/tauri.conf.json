{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TapTap Maker Plus",
  "version": "0.14.1",
  "identifier": "com.taptap.makerplus",
  "build": {
    "frontendDist": "../apps/web/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "node scripts/ensure-dev-web.mjs",
    "beforeBuildCommand": "npm run build:desktop"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "TapTap Maker Plus",
        "url": "desktop-loading.html",
        "width": 1600,
        "height": 900,
        "center": true,
        "resizable": true,
        "dragDropEnabled": false,
        "devtools": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "resources": {
      "../desktop-dist": ""
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "publisher": "TapTap Maker",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "installerHooks": "nsis/installer-hooks.nsh",
        "languages": [
          "SimpChinese"
        ],
        "displayLanguageSelector": false,
        "startMenuFolder": "TapTap Maker Plus"
      }
    }
  }
}
